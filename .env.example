# ─────────────────────────────────────────────────────────────────────────────
# DrAgenda — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
# Local: postgresql://postgres:postgres@localhost:5432/dragenda
DATABASE_URL=

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (better-auth) ───────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth (optional in dev — leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use "dummy" values to activate DEV MODE (no real API calls, mocked responses)
# Use real Stripe test keys (sk_test_...) for integration testing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_ESSENTIAL_PLAN_PRICE_ID=
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=

# ── Messaging / WhatsApp (Fase 5) ────────────────────────────────────────────
# Use "dummy" values to activate DEV MODE (logs to console instead of sending)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
